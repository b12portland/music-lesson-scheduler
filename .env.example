FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Superuser account (created automatically on first run)
# IMPORTANT: Change both of these before deploying to production.
# Use a real email address — this is what you'll log in with.
# The default email below is intentionally fake so the app won't work until you set a real one.
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme123

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your@email.com
